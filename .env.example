# Copy to .env and fill in. .env is gitignored.
HF_TOKEN=hf_your_read_token_here

# Dataset repo on the Hub
HF_DATASET_REPO=ValerianFourel/geodml-papersize

# Where to materialize the dataset on the local machine.
# Large: ~3.5 GB without HTML caches, ~28 GB after extraction.
GEODML_DATA_ROOT=./geodml_data

# Models from the ORIGINAL experiment. These are the checkpoints whose
# behaviour the paper's DML coefficients describe — all mech-interp
# analyses (saliency, probing, weight_analysis) default to these.
# 4-bit quant: ~40 GB VRAM (Llama-3.3-70B) / ~42 GB (Qwen2.5-72B).
# Fits on a single H100-80G; needs device_map='auto' across 2x A100-40G.
ORIGINAL_MODELS=meta-llama/Llama-3.3-70B-Instruct,Qwen/Qwen2.5-72B-Instruct
PRIMARY_MODEL=meta-llama/Llama-3.3-70B-Instruct

# HF Inference API backend for ablation (only used when --backend api).
REMOTE_MODELS=meta-llama/Llama-3.3-70B-Instruct,Qwen/Qwen2.5-72B-Instruct

# Small-proxy fallback. Use only for quick dev iteration — NOT for the
# paper numbers, since an 8B does not produce the 70B/72B behaviour.
PROXY_MODEL=meta-llama/Llama-3.1-8B-Instruct
